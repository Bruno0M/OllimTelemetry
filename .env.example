# Copy this file to .env and adjust for local development.
# Load with: source .env

export OLLIM_ENV=dev

# Override the backend URL (default: https://api.ollim.dev)
export OLLIM_BACKEND_URL=http://localhost:5000

# Isolate config and data from the production instance
export XDG_CONFIG_HOME=/tmp/ollim-dev
export XDG_DATA_HOME=/tmp/ollim-dev
