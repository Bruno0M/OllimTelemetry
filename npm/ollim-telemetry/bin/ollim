#!/usr/bin/env node
'use strict';

const { spawnSync } = require('child_process');
const path = require('path');

const PLATFORM_PACKAGES = {
  'linux-x64':    'ollim-telemetry-linux-x64',
  'linux-arm64':  'ollim-telemetry-linux-arm64',
  'darwin-arm64': 'ollim-telemetry-darwin-arm64',
  'darwin-x64':   'ollim-telemetry-darwin-x64',
};

const platformKey = `${process.platform}-${process.arch}`;
const pkgName = PLATFORM_PACKAGES[platformKey];

if (!pkgName) {
  process.stderr.write(
    `ollim: unsupported platform ${process.platform}/${process.arch}\n` +
    `       supported: linux/darwin × x64/arm64\n`
  );
  process.exit(1);
}

let binPath;
try {
  binPath = require.resolve(`${pkgName}/bin/ollim`);
} catch {
  process.stderr.write(
    `ollim: platform package ${pkgName} is not installed\n` +
    `       try reinstalling: npm install -g ollim-telemetry\n`
  );
  process.exit(1);
}

const binDir = path.dirname(binPath);
const ldPath = process.env.LD_LIBRARY_PATH
  ? `${binDir}:${process.env.LD_LIBRARY_PATH}`
  : binDir;

const result = spawnSync(binPath, process.argv.slice(2), {
  stdio: 'inherit',
  env: { ...process.env, OLLIM_INSTALL_METHOD: 'npm', LD_LIBRARY_PATH: ldPath },
});

if (result.error) {
  process.stderr.write(`ollim: failed to start binary — ${result.error.message}\n`);
  process.exit(1);
}

process.exit(result.status ?? 1);
